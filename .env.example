# Copy to .env and fill in. .env is gitignored; never commit real keys.

# OpenRouter API key. If unset/empty, the offline deterministic MockLLM is used.
OPENROUTER_API_KEY=

# Scoring oracle model id (see https://openrouter.ai/models).
ORACLE_MODEL=anthropic/claude-sonnet-4.5

# SQLite file holding the corpus AND the lift-score cache.
COUNTERPOINT_CACHE_DB_PATH=counterpoint.db

# Embedding strategy: hashing | tfidf | sentence_transformers
COUNTERPOINT_EMBEDDING_BACKEND=hashing

# Model name, used only when the backend is sentence_transformers.
COUNTERPOINT_EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
